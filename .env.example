# Ollama Cloud API — get a key at ollama.com
OLLAMA_HOST=https://api.ollama.com
OLLAMA_API_KEY=your_ollama_api_key_here

# Default model (fallback for all roles if no per-role override set)
LLM_MODEL=gemini-3-flash-preview
LLM_THINK=true

# Per-role model overrides (comment out to fall back to LLM_MODEL)
LLM_MODEL_AGENT=devstral-small-2:24b      # ReAct retrieval agent
LLM_MODEL_GRADER=nemotron-3-nano:30b      # Chunk relevance scorer
LLM_MODEL_JUDGE=gpt-oss:120b             # Quality Judge (ACCEPT/RETRY)
LLM_MODEL_FALLBACK=gemini-3-flash-preview # Direct answer when judge defers

# Per-role think overrides (empty = use global LLM_THINK)
LLM_THINK_AGENT=
LLM_THINK_GRADER=
LLM_THINK_JUDGE=
LLM_THINK_FALLBACK=
