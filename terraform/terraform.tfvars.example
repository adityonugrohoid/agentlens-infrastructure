# AWS Configuration
aws_region   = "us-east-1"
project_name = "genai-portfolio"

# EC2 Configuration
instance_type = "t3.small"

# Security — restrict to your IP in production
# Format: ["your.ip.address/32"]
allowed_ssh_cidr = ["0.0.0.0/0"]

# SSH Key
ssh_public_key_path = "~/.ssh/id_ed25519.pub"

# Ollama Cloud API key — get one at ollama.com
ollama_api_key = "your_ollama_api_key_here"

# GitHub fine-grained PAT (read-only, scoped to app repos)
github_pat = "github_pat_xxxxxxxxxxxx"
